# lzt-dev-mcp settings (env prefix LZT_DEV_MCP_)

# URL of a running lzt-testnet instance. Required for send_request(target="testnet") (the
# default) and get_testnet_status. Left unset by default — no testnet call succeeds silently.
LZT_DEV_MCP_TESTNET_BASE_URL=http://127.0.0.1:9100

# Base URL of a running lzt-flow dev instance.
LZT_DEV_MCP_LZT_FLOW_BASE_URL=http://127.0.0.1:8000

# X-API-Key for lzt-flow's mutating routes (compile_flow, create_run, create_flow, import_flow).
LZT_DEV_MCP_LZT_FLOW_API_KEY=

# Never set to true casually — send_request(target="prod") still always requires an explicit
# per-call token regardless of this flag (see 00-decisions.md D-4); this only exists as a
# secondary intent signal, not a bypass.
LZT_DEV_MCP_ALLOW_PROD=false
